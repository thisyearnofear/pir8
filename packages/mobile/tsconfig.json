{
  "extends": "expo-router/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@pir8/core": ["../core/src/index.ts"]
    },
    "typeRoots": ["./node_modules/@types", "../core/node_modules/@types"]
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
