    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-wallets": "^0.19.37",
    "@solana/web3.js": "^1.98.4",
    "clsx": "^2.0.0",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.25",
    "lucide-react": "0.563.0",
    "next": "^16.0.7",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "three": "^0.181.2",
    "ws": "8.19.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
